# Copy this file to `.env` and fill values locally. NEVER commit `.env`.
# The old prototype hardcoded a DB password in source — this is the fix.

# Database backend: sqlite (default, local/CI) or postgres (Docker Compose default)
DB_BACKEND=sqlite

# SQLite (local/CI). Path usually comes from config.yaml; override here if desired.
SQLITE_PATH=data/processed/cars.db

# Postgres (used when DB_BACKEND=postgres; docker-compose reads these too)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=cars
POSTGRES_PASSWORD=
POSTGRES_DB=cars
